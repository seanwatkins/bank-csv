
#!/bin/sh

source .env

curl -s -X POST "http://localhost:8086/api/v2/query?org=my-org" \
  -H "Authorization: Token $INFLUX_TOKEN" \
  -H "Content-Type: application/vnd.flux" \
  -d 'from(bucket: "banking")
  |> range(start: -365d)
  |> filter(fn: (r) => r._measurement == "bank_transaction")
  |> limit(n: 3)'
  
